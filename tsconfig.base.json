{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@storytime/types": ["packages/types/src"],
      "@storytime/validators": ["packages/validators/src"],
      "@storytime/prompts": ["packages/prompts/src"],
      "@storytime/config": ["packages/config/src"],
      "@storytime/ui-tokens": ["packages/ui-tokens/src"]
    }
  }
}
